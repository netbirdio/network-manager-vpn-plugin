# Generated by GoReleaser from packaging/rpm/network-manager-netbird.spec.tmpl

%global debug_package %{nil}

Name:           {{ .PackageName }}
Version:        {{ .Version }}
Release:        1%{?dist}
Summary:        {{ .Summary }}

License:        {{ .License }}
URL:            {{ .URL }}
Source0:        {{ .Source }}

BuildRequires:  gcc
BuildRequires:  golang
BuildRequires:  make
BuildRequires:  pkgconfig(gtk+-3.0)
BuildRequires:  pkgconfig(gtk4)
BuildRequires:  pkgconfig(libnm)
BuildRequires:  pkgconfig(libnma)
BuildRequires:  pkgconfig(libnma-gtk4)
BuildRequires:  policycoreutils
BuildRequires:  selinux-policy-devel
BuildRequires:  selinux-policy-targeted

Requires:       NetworkManager
Requires:       NetworkManager-libnm
Requires:       gtk3
Requires:       gtk4
Requires:       libnma
Requires:       libnma-gtk4
Requires:       netbird
Requires:       xdg-utils
Requires(post): policycoreutils
Requires(postun): policycoreutils

%description
{{ .Description }}

%prep
%autosetup -n %{name}-%{version}

%build
mkdir -p bin bin/rpm
export CGO_ENABLED=0
go build -trimpath -ldflags "-s -w" -o bin/nm-netbird-service ./cmd/nm-netbird-service
go build -trimpath -ldflags "-s -w" -o bin/nm-netbird-auth-dialog ./cmd/nm-netbird-auth-dialog

scripts/build-release-properties.sh bin/rpm
make -C packaging/selinux clean all

%install
install -D -m0755 bin/nm-netbird-service \
  %{buildroot}%{_libexecdir}/nm-netbird-service
install -D -m0755 bin/nm-netbird-auth-dialog \
  %{buildroot}%{_libexecdir}/nm-netbird-auth-dialog

install -D -m0755 bin/rpm/libnm-vpn-plugin-netbird.so \
  %{buildroot}%{_prefix}/lib/NetworkManager/libnm-vpn-plugin-netbird.so
install -D -m0755 bin/rpm/libnm-vpn-plugin-netbird-editor.so \
  %{buildroot}%{_prefix}/lib/NetworkManager/libnm-vpn-plugin-netbird-editor.so
install -D -m0755 bin/rpm/libnm-gtk4-vpn-plugin-netbird-editor.so \
  %{buildroot}%{_prefix}/lib/NetworkManager/libnm-gtk4-vpn-plugin-netbird-editor.so

install -D -m0644 packaging/NetworkManager/VPN/nm-netbird-service.name \
  %{buildroot}%{_sysconfdir}/NetworkManager/VPN/nm-netbird-service.name
install -D -m0644 packaging/dbus-1/system.d/nm-netbird-service.conf \
  %{buildroot}%{_datadir}/dbus-1/system.d/nm-netbird-service.conf
install -D -m0644 packaging/NetworkManager/conf.d/90-netbird-unmanaged.conf \
  %{buildroot}%{_sysconfdir}/NetworkManager/conf.d/90-netbird-unmanaged.conf

install -D -m0644 packaging/selinux/nm_netbird.pp \
  %{buildroot}%{_datadir}/selinux/packages/nm_netbird.pp
install -D -m0644 packaging/selinux/nm_netbird.te \
  %{buildroot}%{_datadir}/%{name}/selinux/nm_netbird.te
install -D -m0644 packaging/selinux/nm_netbird.fc \
  %{buildroot}%{_datadir}/%{name}/selinux/nm_netbird.fc
install -D -m0644 LICENSE \
  %{buildroot}%{_datadir}/doc/%{name}/LICENSE

%post
if [ -f %{_datadir}/selinux/packages/nm_netbird.pp ] && command -v semodule >/dev/null 2>&1; then
  if semodule -i %{_datadir}/selinux/packages/nm_netbird.pp >/dev/null 2>&1; then
    mkdir -p %{_sharedstatedir}/%{name}
    : >%{_sharedstatedir}/%{name}/selinux-policy-installed
    echo "installed SELinux policy module nm_netbird"
  else
    echo "warning: could not install SELinux policy module %{_datadir}/selinux/packages/nm_netbird.pp" >&2
  fi
fi

if command -v restorecon >/dev/null 2>&1; then
  for path in \
    %{_libexecdir}/nm-netbird-service \
    %{_libexecdir}/nm-netbird-auth-dialog \
    /run/netbird.sock \
    /var/run/netbird.sock; do
    [ -e "$path" ] && restorecon "$path" >/dev/null 2>&1 || true
  done
fi

if command -v dbus-send >/dev/null 2>&1; then
  dbus-send --system --type=method_call --dest=org.freedesktop.DBus \
    /org/freedesktop/DBus org.freedesktop.DBus.ReloadConfig >/dev/null 2>&1 || true
elif command -v busctl >/dev/null 2>&1; then
  busctl call org.freedesktop.DBus /org/freedesktop/DBus \
    org.freedesktop.DBus ReloadConfig >/dev/null 2>&1 || true
elif command -v systemctl >/dev/null 2>&1; then
  systemctl reload dbus >/dev/null 2>&1 || true
fi

if command -v systemctl >/dev/null 2>&1 && systemctl is-active --quiet NetworkManager >/dev/null 2>&1; then
  systemctl reload NetworkManager >/dev/null 2>&1 || true
elif command -v nmcli >/dev/null 2>&1; then
  nmcli general reload >/dev/null 2>&1 || true
fi

%postun
if [ "$1" -eq 0 ]; then
  marker=%{_sharedstatedir}/%{name}/selinux-policy-installed
  if [ -e "$marker" ] && command -v semodule >/dev/null 2>&1; then
    if semodule -l 2>/dev/null | awk '{ print $1 }' | grep -qx nm_netbird; then
      semodule -r nm_netbird >/dev/null 2>&1 || true
    fi
    rm -f "$marker"
    rmdir %{_sharedstatedir}/%{name} 2>/dev/null || true
  fi
fi

if command -v dbus-send >/dev/null 2>&1; then
  dbus-send --system --type=method_call --dest=org.freedesktop.DBus \
    /org/freedesktop/DBus org.freedesktop.DBus.ReloadConfig >/dev/null 2>&1 || true
elif command -v busctl >/dev/null 2>&1; then
  busctl call org.freedesktop.DBus /org/freedesktop/DBus \
    org.freedesktop.DBus ReloadConfig >/dev/null 2>&1 || true
elif command -v systemctl >/dev/null 2>&1; then
  systemctl reload dbus >/dev/null 2>&1 || true
fi

if command -v systemctl >/dev/null 2>&1 && systemctl is-active --quiet NetworkManager >/dev/null 2>&1; then
  systemctl reload NetworkManager >/dev/null 2>&1 || true
elif command -v nmcli >/dev/null 2>&1; then
  nmcli general reload >/dev/null 2>&1 || true
fi

%files
%license %{_datadir}/doc/%{name}/LICENSE
%{_libexecdir}/nm-netbird-service
%{_libexecdir}/nm-netbird-auth-dialog
%{_prefix}/lib/NetworkManager/libnm-vpn-plugin-netbird.so
%{_prefix}/lib/NetworkManager/libnm-vpn-plugin-netbird-editor.so
%{_prefix}/lib/NetworkManager/libnm-gtk4-vpn-plugin-netbird-editor.so
%{_sysconfdir}/NetworkManager/VPN/nm-netbird-service.name
%{_datadir}/dbus-1/system.d/nm-netbird-service.conf
%config(noreplace) %{_sysconfdir}/NetworkManager/conf.d/90-netbird-unmanaged.conf
%{_datadir}/selinux/packages/nm_netbird.pp
%{_datadir}/%{name}/selinux/nm_netbird.te
%{_datadir}/%{name}/selinux/nm_netbird.fc

%changelog
